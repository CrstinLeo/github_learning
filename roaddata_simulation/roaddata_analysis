    print("="*180)
    
    for stats in stats_list:
        print(f"\nSegment ID: {stats['segment_id']} | Range: {stats['segment_range']}")
        print("-" * 180)
        
        # 风速数据质量信息
        print(f"Data Cleaning (Wind Speed):")
        print(f"  Original Count: {stats['wind_speed_original_count']}, "
              f"Outliers Removed: {stats['wind_speed_outlier_count']}, "
              f"Clean Count: {stats['wind_speed_clean_count']}, "
              f"Outlier Ratio: {stats['wind_speed_outlier_ratio']*100:.2f}%")
        
        # 风速统计
        print(f"\nWind Speed Statistics (cleaned data):")
        print(f"  Mean: {stats['wind_speed_mean']:.4f} m/s, "
              f"Std: {stats['wind_speed_std']:.4f} m/s, "
              f"Median: {stats['wind_speed_median']:.4f} m/s")
        print(f"  Min: {stats['wind_speed_min']:.4f} m/s, "
              f"Max: {stats['wind_speed_max']:.4f} m/s, "
              f"P90: {stats['wind_speed_p90']:.4f} m/s")
        
        # 正态性检验
        normality_judgment = "✓ Normal (p ≥ 0.05)" if stats['wind_speed_is_normal'] else "✗ Non-Normal (p < 0.05)"
        print(f"  Normality Test (Shapiro-Wilk): p-value = {stats['wind_speed_shapiro_p']:.6f} → {normality_judgment}")
        
        # 风向线性统计
        print(f"\nWind Direction Statistics (Linear):")
        print(f"  Mean: {stats['wind_dir_mean']:.2f}°, "
              f"Std: {stats['wind_dir_std']:.2f}°, "
              f"Median: {stats['wind_dir_median']:.2f}°")
        print(f"  Min: {stats['wind_dir_min']:.2f}°, "
              f"Max: {stats['wind_dir_max']:.2f}°, "
              f"Count: {stats['wind_dir_count']}")
        
        # 风向圆统计
        print(f"\nWind Direction Statistics (Circular - sin/cos transformed):")
        print(f"  Circular Mean: {stats['wind_dir_circ_mean']:.2f}°")
        print(f"  Circular Std: {stats['wind_dir_circ_std']:.6f} rad")
        print(f"  Consistency (R): {stats['wind_dir_consistency_R']:.6f} (Range: 0~1, closer to 1 = more concentrated)")
        
        # 判断风向集中度
        if stats['wind_dir_consistency_R'] > 0.9:
            concentration = "Very High (consistent direction)"
        elif stats['wind_dir_consistency_R'] > 0.7:
            concentration = "High"
        elif stats['wind_dir_consistency_R'] > 0.5:
            concentration = "Moderate"
        else:
            concentration = "Low (dispersed)"
        print(f"  Direction Concentration: {concentration}")
    
    print("\n" + "="*180 + "\n")


